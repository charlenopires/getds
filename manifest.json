{
  "manifest_version": 3,
  "name": "getds — Design System Extractor",
  "version": "0.1.0",
  "description": "Extracts design system tokens, components, and patterns from any web page",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "downloads"
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "getds"
  },
  "background": {
    "service_worker": "src/background/background.js",
    "type": "module"
  },
  "content_scripts": [],
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}
